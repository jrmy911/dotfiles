{
  "lastChangelogVersion": "0.80.2",
  "defaultProvider": "openrouter",
  "defaultModel": "openai/gpt-5.5",
  "defaultThinkingLevel": "low",
  "theme": "dark/bauhaus",
  "treeFilterMode": "default",
  "quietStartup": false,
  "hideThinkingBlock": true,
  "packages": [
    "npm:pi-web-access",
    "npm:pi-subagents",
    "npm:@juicesharp/rpiv-advisor",
    "npm:@juicesharp/rpiv-ask-user-question",
    "npm:pi-tool-display",
    {
      "source": "npm:@codesook/pi-welcome-screen",
      "extensions": [
        "-src/index.ts"
      ]
    },
    "npm:@tmustier/pi-files-widget"
  ],
  "subagents": {
    "agentOverrides": {
      "scout": {
        "model": "openrouter/openai/gpt-5-mini",
        "thinking": "low"
      },
      "reviewer": {
        "model": "openrouter/openai/gpt-5.5",
        "thinking": "high"
      },
      "worker": {
        "model": "openrouter/openai/gpt-5.5",
        "thinking": "medium"
      },
      "planner": {
        "model": "openrouter/openai/gpt-5.5",
        "thinking": "high"
      },
      "oracle": {
        "model": "openrouter/openai/gpt-5.5",
        "thinking": "high"
      },
      "researcher": {
        "model": "openrouter/openai/gpt-5.5",
        "thinking": "medium"
      }
    }
  }
}