{
    "collaboration_panel": {
        "button": false,
        "dock": "right"
    },
    "document_symbols": "off",
    "outline_panel": {
        "dock": "left",
        "git_status": true,
        "button": false
    },
    "active_pane_modifiers": {
        "border_size": 2.0,
        "inactive_opacity": 0.7
    },
    "preview_tabs": {
