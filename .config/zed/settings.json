        "Ansible": [
            "**.ansible.yml",
            "**.ansible.yaml",
            "**/defaults/*.yml",
            "**/defaults/*.yaml",
            "**/meta/*.yml",
            "**/meta/*.yaml",
            "**/tasks/*.yml",
            "**/tasks/*.yaml",
            "**/handlers/*.yml",
            "**/handlers/*.yaml",
            "**/group_vars/*.yml",
            "**/group_vars/*.yaml",
            "**/host_vars/*.yml",
            "**/host_vars/*.yaml",
            "**/playbooks/*.yml",
            "**/playbooks/*.yaml",
            "**playbook*.yml",
            "**playbook*.yaml"
        ]
