    },
    "scrollbar": {
        "axes": {
            "vertical": false,
            "horizontal": false
        },
        "diagnostics": "warning",
        "show": "never"
    },
    "buffer_font_family": "JetBrainsMono Nerd Font",
    "ssh_connections": [
        {
            "host": "192.168.1.250",
