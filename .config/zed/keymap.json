// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-shift-d": "diagnostics::Deploy"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-shift-m": null
    }
  },
  {
    "bindings": {
      "space a g": "agent::Toggle"
    }
  },
  {
    "context": "((vim_mode == helix_normal || vim_mode == helix_select) && !menu)",
    "bindings": {
      "shift-\\": "pane::SplitRight"
    }
  },
  {
    "context": "((VimControl && !menu) || (!Editor && !Terminal))",
    "bindings": {
      "ctrl-space shift-\\": "pane::SplitVertical"
    }
  },
  {
    "context": "((VimControl && !menu) || (!Editor && !Terminal))",
    "bindings": {
      "ctrl-space -": "pane::SplitHorizontal"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "space alt-b": "workspace::ToggleRightDock"
    }
  },
  {
    "bindings": {
      "space d": "editor::ToggleDiagnostics"
    }
  },
  {
    "context": "(ProjectPanel && not_editing)",
    "bindings": {
      "space ]": "project_panel::SelectNextDiagnostic"
    }
  },
  {
    "context": "((vim_mode == helix_normal || vim_mode == helix_select) && !menu)",
    "bindings": {
      "space c a": "editor::ToggleCodeActions"
    }
  },
  {
    "context": "((vim_mode == helix_normal || vim_mode == helix_select) && !menu)",
    "bindings": {
      "space a": null
    }
  },
  {
    "bindings": {
      "space g r": "git::RenameBranch"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "space g b": "git::Branch"
    }
  },
  {
    "bindings": {
      "space g d": "git::BranchDiff"
    }
  },
  {
    "bindings": {
      "space a a": "git::Add"
    }
  },
  {
    "context": "GitPanel",
    "bindings": {
      "space g c": "git::Commit"
    }
  },
  {
    "bindings": {
      "ctrl-shift-o": [
        "projects::OpenRemote",
        {
          "from_existing_connection": false,
          "create_new_window": false
        }
      ]
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-alt-shift-o": null
    }
  },
  {
    "context": "(Editor && mode == full)",
    "bindings": {
      "space f s": "outline::Toggle"
    }
  },
  {
    "context": "(Editor && mode == full)",
    "bindings": {
      "ctrl-shift-o": null
    }
  },
  {
    "context": "((vim_mode == helix_normal || vim_mode == helix_select) && !menu)",
    "bindings": {
      "space f s": "outline::Toggle"
    }
  },
  {
    "bindings": {
      "space l g": "git_panel::Toggle"
    }
  },
  {
    "context": "((os != macos && Editor) && (edit_prediction && (showing_completions || in_leading_whitespace)))",
    "bindings": {
      "space l": "editor::AcceptEditPrediction"
    }
  },
  {
    "bindings": {
      "space p v": "project_panel::Toggle"
    }
  },
  {
    "context": "GitPanel",
    "bindings": {
      "space g p": "git::Push"
    }
  },
  {
    "context": "GitPanel",
    "unbind": {
      "ctrl-g up": "git::Push"
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "space s": "search::ToggleReplace"
    }
  },
  {
    "context": "Pane",
    "unbind": {
      "ctrl-alt-shift-h": "search::ToggleReplace"
    }
  },
  {
    "context": "(vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "unbind": {
      "space s": "outline::Toggle"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-~": "workspace::NewTerminal"
    }
  },
  {
    "bindings": {
      "space enter": "workspace::NewCenterTerminal"
    }
  }
]
